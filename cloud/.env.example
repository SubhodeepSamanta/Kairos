# Kairos cloud config. Copy this file to `.env` and fill it in.
#   cp cloud/.env.example cloud/.env

# WebSocket port the cloud listens on. The client's CLOUD_URL must point here.
PORT=3000

# Shared secret. Must be identical in client/.env. Pick any long random string.
# Leave blank to disable auth (fine for local-only use).
CLIENT_SECRET=change-me-to-a-long-random-string

# --- LLM providers (you need AT LEAST ONE) ---
# Groq is the recommended primary — free, fast. Get a key: https://console.groq.com/keys
GROQ_API_KEY=
# OpenRouter fallback (free tier available): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# NVIDIA fallback (optional): https://build.nvidia.com
NVIDIA_API_KEY=

# --- Optional ---
# Telegram bot token from @BotFather. Omit to run CLI-only.
TELEGRAM_BOT_TOKEN=
# Postgres (e.g. Neon). Omit to store memory in a local JSON file under cloud/data/.
DATABASE_URL=
# Tokens-per-minute pacing ceiling (default 10000).
LLM_TPM_LIMIT=10000
