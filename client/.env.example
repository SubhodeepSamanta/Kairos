# Kairos client config. Copy this file to `.env` and fill it in.
#   cp client/.env.example client/.env

# Where the cloud is listening. Use the PORT from cloud/.env.
# Local: ws://localhost:3000   Hosted: wss://your-app.onrender.com
CLOUD_URL=ws://localhost:3000

# Must match CLIENT_SECRET in cloud/.env exactly.
CLIENT_SECRET=change-me-to-a-long-random-string

# Set to false to disable human-like delays (faster, more robotic).
HUMANIZE=true

# Optional: default real browser to drive (chrome | brave | edge).
DEFAULT_BROWSER=chrome
